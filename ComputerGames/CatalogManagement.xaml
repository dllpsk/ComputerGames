<Window x:Class="ComputerGames.CatalogManagement"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Управление каталогом игр" Height="650" Width="1050"
        WindowStartupLocation="CenterOwner" Background="#0F172A">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DataGrid x:Name="GamesDataGrid" 
                  Grid.Row="0" 
                  AutoGenerateColumns="False" 
                  IsReadOnly="True"
                  Background="#1E293B" 
                  RowBackground="#1E293B" 
                  AlternatingRowBackground="#334155"
                  Foreground="White" 
                  BorderBrush="#334155"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#334155"
                  SelectionMode="Single">
            <DataGrid.Resources>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#334155"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Padding" Value="10,8"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="BorderThickness" Value="0,0,1,0"/>
                    <Setter Property="BorderBrush" Value="#475569"/>
                </Style>
                <Style TargetType="DataGridRow">
                    <Style.Resources>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#475569"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White"/>
                    </Style.Resources>
                </Style>
            </DataGrid.Resources>

            <DataGrid.Columns>
                <DataGridTextColumn Header="Название игры" Binding="{Binding Title}" Width="2*"/>
                <DataGridTextColumn Header="Жанр" Binding="{Binding Genre}" Width="1.2*"/>
                <DataGridTextColumn Header="Режим игры" Binding="{Binding GameMode}" Width="1.2*"/>
                <DataGridTextColumn Header="Возраст" Binding="{Binding AgeRating, StringFormat=\{0\}+}" Width="0.8*"/>
                <DataGridTextColumn Header="Рейтинг" Binding="{Binding Rating}" Width="1*"/>
                <DataGridTextColumn Header="Дата выхода" Binding="{Binding ReleaseDate, StringFormat=\{0:dd.MM.yyyy\}}" Width="1.3*"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="1" 
                Background="#1E293B" 
                CornerRadius="12" 
                Margin="0,15,0,0" 
                Padding="15"
                BorderBrush="#334155"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="180"/>
                </Grid.ColumnDefinitions>

                <WrapPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel Margin="6,4">
                        <TextBlock Text="Название:" Foreground="#94A3B8" FontSize="12" Margin="0,0,0,4"/>
                        <TextBox x:Name="TxtTitle" Width="180" Height="28" Background="#0F172A" Foreground="White" BorderBrush="#475569" VerticalContentAlignment="Center" Padding="5,0"/>
                    </StackPanel>

                    <StackPanel Margin="6,4">
                        <TextBlock Text="Жанр:" Foreground="#94A3B8" FontSize="12" Margin="0,0,0,4"/>
                        <TextBox x:Name="TxtGenre" Width="120" Height="28" Background="#0F172A" Foreground="White" BorderBrush="#475569" VerticalContentAlignment="Center" Padding="5,0"/>
                    </StackPanel>

                    <StackPanel Margin="6,4">
                        <TextBlock Text="Тип (Класс):" Foreground="#94A3B8" FontSize="12" Margin="0,0,0,4"/>
                        <ComboBox x:Name="CmbType" Width="130" Height="28" Background="#0F172A" BorderBrush="#475569">
                            <ComboBoxItem Content="Single" IsSelected="True"/>
                            <ComboBoxItem Content="Multiplayer"/>
                            <ComboBoxItem Content="Online"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Margin="6,4">
                        <TextBlock Text="Возраст:" Foreground="#94A3B8" FontSize="12" Margin="0,0,0,4"/>
                        <TextBox x:Name="TxtAge" Width="60" Height="28" Background="#0F172A" Foreground="White" BorderBrush="#475569" VerticalContentAlignment="Center" Padding="5,0"/>
                    </StackPanel>

                    <StackPanel Margin="6,4">
                        <TextBlock Text="Рейтинг (0-10):" Foreground="#94A3B8" FontSize="12" Margin="0,0,0,4"/>
                        <TextBox x:Name="TxtRating" Width="80" Height="28" Background="#0F172A" Foreground="White" BorderBrush="#475569" VerticalContentAlignment="Center" Padding="5,0"/>
                    </StackPanel>

                    <StackPanel Margin="6,4">
                        <TextBlock Text="Дата выхода:" Foreground="#94A3B8" FontSize="12" Margin="0,0,0,4"/>
                        <DatePicker x:Name="DpRelease" Width="120" Height="28"/>
                    </StackPanel>

                    <StackPanel Margin="6,4">
                        <TextBlock Text="Ссылка на обложку (URL):" Foreground="#94A3B8" FontSize="12" Margin="0,0,0,4"/>
                        <TextBox x:Name="TxtImage" Width="200" Height="28" Background="#0F172A" Foreground="White" BorderBrush="#475569" VerticalContentAlignment="Center" Padding="5,0"/>
                    </StackPanel>
                </WrapPanel>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right" Width="165">
                    <Button Content="➕ Добавить игру" 
                            Height="32" 
                            Background="#059669" 
                            Foreground="White" 
                            FontWeight="Bold" 
                            BorderThickness="0"
                            Margin="0,0,0,8"
                            Cursor="Hand"
                            Click="AddButton_Click"/>

                    <Button Content="🗑️ Удалить выбранную" 
                            Height="32" 
                            Background="#DC2626" 
                            Foreground="White" 
                            FontWeight="Bold" 
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="DeleteButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>